<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hotel.DashboardController"
            styleClass="root-shell">
    <left>
        <VBox prefWidth="240.0" styleClass="sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0" />
            </padding>

            <Label text="GRAND VISTA" styleClass="brand-title" />
            <Label text="Hotel Management System" styleClass="brand-subtitle" />
            <Label fx:id="sessionTitleLabel" styleClass="brand-session-title" />
            <Label fx:id="sessionSubtitleLabel" styleClass="brand-caption" />

            <Button fx:id="overviewBtn" mnemonicParsing="false" onAction="#showOverview" styleClass="nav-button" text="Overview" />
            <Button fx:id="roomsBtn" mnemonicParsing="false" onAction="#showRooms" styleClass="nav-button" text="Rooms" />
            <Button fx:id="customersBtn" mnemonicParsing="false" onAction="#showCustomers" styleClass="nav-button" text="Customers" />
            <Button fx:id="bookingsBtn" mnemonicParsing="false" onAction="#showBookings" styleClass="nav-button" text="Bookings" />
            <Button fx:id="billingBtn" mnemonicParsing="false" onAction="#showBilling" styleClass="nav-button" text="Billing" />
            <Button fx:id="checkoutBtn" mnemonicParsing="false" onAction="#showCheckout" styleClass="nav-button" text="Check-out" />
            <Button fx:id="smartBtn" mnemonicParsing="false" onAction="#showSmart" styleClass="nav-button" text="Smart Finder" />
            <Button fx:id="analyticsBtn" mnemonicParsing="false" onAction="#showAnalytics" styleClass="nav-button" text="Analytics" />
            <Region VBox.vgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="subtle-button" text="Logout" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-shell" />
    </center>
</BorderPane>
